{
  "name": "meld",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "package:web": "npm run build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "electron:dev": "concurrently --kill-others-on-fail -n vite,electron -c cyan,magenta \"npm run dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "sim": "tsx src/sim/run.ts",
    "sim:techniques": "tsx src/sim/techniques.ts"
  },
  "dependencies": {
    "three": "0.165.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/three": "^0.165.0",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.0.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.marilefabled.meld",
    "productName": "Meld In Your Hand",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.games"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
